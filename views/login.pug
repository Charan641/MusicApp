extends layout

block content
    .auth-container(style="min-height: 80vh; display: flex; align-items: center; justify-content: center; background: radial-gradient(circle at 50% 50%, #1a0033 0%, #0d0d0d 100%);")
        .auth-card(style="width: 100%; max-width: 450px; padding: 40px; background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); border-radius: 24px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 15px 35px rgba(0,0,0,0.5); font-family: 'Outfit', sans-serif;")
            div(style="text-align: center; margin-bottom: 30px;")
                i.fas.fa-music(style="font-size: 3rem; color: var(--primary);")
                h2(style="margin-top: 15px; font-size: 2rem; font-weight: 600; color: white;") Welcome Back
                p(style="color: var(--text-muted);") Sign in to your premium account

            if success
                .success-box(style="background: rgba(46, 204, 113, 0.1); border-left: 4px solid #2ecc71; padding: 12px; margin-bottom: 20px; border-radius: 8px;")
                    p(style="color: #2ecc71; font-size: 0.9rem; margin: 0;") #{success}

            if error
                .error-box(style="background: rgba(231, 76, 60, 0.1); border-left: 4px solid #e74c3c; padding: 12px; margin-bottom: 20px; border-radius: 8px;")
                    p(style="color: #e74c3c; font-size: 0.9rem; margin: 0;") #{error}

            form(method="POST", action="/login")
                .form-group(style="margin-bottom: 20px;")
                    label(style="display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem;") Email Address
                    input(
                        type="email", 
                        name="email", 
                        placeholder="name@example.com", 
                        required,
                        style="width: 100%; padding: 15px; border-radius: 12px; border: 1px solid #333; background: rgba(0,0,0,0.3); color: white; outline: none; transition: border-color 0.3s;"
                    )
                
                .form-group(style="margin-bottom: 30px;")
                    label(style="display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem;") Password
                    input(
                        type="password", 
                        name="password", 
                        placeholder="••••••••", 
                        required,
                        style="width: 100%; padding: 15px; border-radius: 12px; border: 1px solid #333; background: rgba(0,0,0,0.3); color: white; outline: none;"
                    )

                button(
                    type="submit", 
                    style="width: 100%; padding: 16px; background: linear-gradient(90deg, var(--primary) 0%, var(--secondary) 100%); color: white; border: none; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: transform 0.2s;"
                ) Log In

            div(style="text-align: center; margin-top: 30px; font-size: 0.95rem;")
                span(style="color: var(--text-muted);") New here? 
                a(href="/signup", style="color: var(--primary); font-weight: 600; text-decoration: none;") Create an Account