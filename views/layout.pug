doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title #{title} | Jamendo Music
        link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
        link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap", rel="stylesheet")
        
        style.
            /* --- CSS Variables --- */
            :root {
                --primary: #9400ff;
                --secondary: #6200ea;
                --background: #0d0d0d;
                --card-bg: #1a1a1a;
                --text: #ffffff;
                --text-muted: #b3b3b3;
                --accent: #00e5ff;
            }

            /* --- Global --- */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                background-color: var(--background);
                color: var(--text);
                font-family: 'Outfit', sans-serif;
                line-height: 1.6;
                padding-bottom: 120px; /* Room for player bar */
            }

            a {
                color: inherit;
                text-decoration: none;
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
                padding: 20px 30px;
            }

            /* --- Header --- */
            header {
                background: rgba(13, 13, 13, 0.8);
                backdrop-filter: blur(10px);
                position: sticky;
                top: 0;
                z-index: 1000;
            }

            nav {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 1rem 2rem;
            }

            .logo {
                font-size: 1.5rem;
                font-weight: 600;
                display: flex;
                align-items: center;
                gap: 10px;
                color: var(--primary);
                cursor: pointer;
            }

            .nav-links {
                list-style: none;
                display: flex;
                gap: 30px;
            }

            .nav-links a:hover {
                color: var(--primary);
            }

            /* --- Hero --- */
            .hero {
                text-align: center;
                padding: 80px 20px 40px;
            }

            .hero h1 {
                font-size: 3.8rem;
            }

            .hero p {
                font-size: 1.3rem;
            }

            /* --- Grid Layout --- */
            .grid-layout {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 35px;
                padding: 30px 0;
            }

            /* --- Song Card --- */
            .song-card {
                background: var(--card-bg);
                border-radius: 18px;
                padding: 18px;
                border: 1px solid #333;
                transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
                cursor: pointer;
                position: relative;
            }

            .song-card:hover, .song-card.active {
                transform: translateY(-8px) scale(1.02);
                background: #252525;
                border-color: var(--primary);
                box-shadow: 0 10px 30px rgba(148, 0, 255, 0.3);
            }

            .song-card.active {
                border-width: 2px;
            }

            .card-image-wrap {
                position: relative;
                border-radius: 14px;
                overflow: hidden;
                aspect-ratio: 1/1;
                margin-bottom: 15px;
            }

            .card-image-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .play-btn {
                width: 60px;
                height: 60px;
                font-size: 1.3rem;
            }

            .song-card:hover .play-btn {
                opacity: 1;
                transform: scale(1);
            }

            .card-content h3 {
                font-size: 1.3rem;
                margin-bottom: 6px;
            }

            .card-content p {
                font-size: 1rem;
            }

            .card-footer {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-top: 15px;
            }

            .like-btn {
                background: transparent;
                border: none;
                color: var(--text-muted);
                font-size: 1.2rem;
                cursor: pointer;
                transition: color 0.3s ease;
            }

            .like-btn:hover, .like-btn.liked {
                color: #ff3d00;
            }

            /* --- Player Bar --- */
            .player-bar {
                position: fixed;
                bottom: 0;
                left: 0;
                width: 100%;
                background: rgba(26, 26, 26, 0.9);
                backdrop-filter: blur(20px);
                border-top: 1px solid #333;
                padding: 15px 0;
                z-index: 2000;
            }

            .player-bar .container {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 20px;
            }

            #current-song-info {
                display: flex;
                align-items: center;
                gap: 15px;
                width: 30%;
            }

            #current-album-art {
                width: 70px;
                height: 70px;
                border-radius: 10px;
            }

            .song-details h4 {
                font-size: 0.95rem;
                margin-bottom: 2px;
            }

            .song-details p {
                font-size: 0.8rem;
                color: var(--text-muted);
            }

            .controls {
                flex-grow: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 12px;
            }

            audio {
                width: 100%;
                max-width: 600px;
                height: 45px;
            }

            .nav-btn {
                background: transparent;
                border: 2px solid #444;
                color: var(--text);
                width: 42px;
                height: 42px;
                border-radius: 50%;
                font-size: 1.1rem;
                cursor: pointer;
                transition: all 0.2s ease;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

            .nav-btn:hover:not(:disabled) {
                background: var(--primary);
                border-color: var(--primary);
                transform: scale(1.1);
            }

            .nav-btn:disabled {
                opacity: 0.3;
                cursor: not-allowed;
            }

            .recommendations-trigger {
                width: 20%;
                display: flex;
                justify-content: flex-end;
            }

            #show-recommendations {
                background: var(--primary);
                color: white;
                border: none;
                padding: 10px 20px;
                border-radius: 20px;
                font-weight: 600;
                cursor: pointer;
            }

            /* --- Recommendations Panel --- */
            #recommendations-panel {
                position: fixed;
                bottom: 80px;
                left: 0;
                width: 100%;
                background: #111;
                border-top: 1px solid #333;
                max-height: 400px;
                overflow-y: auto;
                transition: transform 0.4s ease;
                z-index: 1000;
            }

            #recommendations-panel.hidden {
                transform: translateY(100%);
            }

            .empty-state {
                text-align: center;
                padding: 60px 0;
                color: var(--text-muted);
            }

            .empty-state i {
                font-size: 3rem;
                margin-bottom: 20px;
            }

            .pulse {
                box-shadow: 0 0 0 0 rgba(148, 0, 255, 0.7);
                animation: pulse 2s infinite;
            }

            @keyframes pulse {
                0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(148, 0, 255, 0.7); }
                70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(148, 0, 255, 0); }
                100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(148, 0, 255, 0); }
            }

    body
        header
            nav.container
                a.logo(href="/")
                    i.fas.fa-music
                    span MusicStream
                ul.nav-links
                    li: a(href="/") Home
                    li: a(href="/favorites") Favorites
        
        main.container
            block content

        if user
            footer.player-bar
                .container
                    #current-song-info
                        img#current-album-art(src="https://via.placeholder.com/60", alt="Album Art")
                        .song-details
                            h4#current-track-title Select a track
                            p#current-track-artist ---
                    
                    .controls
                        button#prev-btn.nav-btn(title="Previous")
                            i.fas.fa-step-backward
                        audio#audio-player(controls, autoplay)
                            source(src="", type="audio/mpeg")
                        button#next-btn.nav-btn(title="Next")
                            i.fas.fa-step-forward
                    
                    .recommendations-trigger
                        button#show-recommendations Recommendations

        if user
            #recommendations-panel.hidden
                .container
                    h3 Looking for similar tracks?
                    p(style="margin-bottom: 20px; color: var(--text-muted);") Discover new music based on your taste.
                    a#view-all-recommendations(href="/", style="display:inline-block; padding:12px 25px; background:var(--primary); color:white; border-radius:30px; font-weight:600;") View Recommendations
        
        if user
            script.
                document.addEventListener('DOMContentLoaded', () => {
                    const audioPlayer = document.getElementById('audio-player');
                    const currentAlbumArt = document.getElementById('current-album-art');
                    const currentTrackTitle = document.getElementById('current-track-title');
                    const currentTrackArtist = document.getElementById('current-track-artist');
                    const showRecommendationsBtn = document.getElementById('show-recommendations');
                    const recommendationsPanel = document.getElementById('recommendations-panel');
                    const recommendationsList = document.getElementById('recommendations-list');

                    let playlist = [];
                    let currentIndex = 0;
                    let currentArtist = '';

                    const prevBtn = document.getElementById('prev-btn');
                    const nextBtn = document.getElementById('next-btn');

                    function updateNavButtons() {
                        prevBtn.disabled = currentIndex <= 0;
                        nextBtn.disabled = currentIndex >= playlist.length - 1;
                    }

                    prevBtn.disabled = true;
                    nextBtn.disabled = true;

                    function playTrack(trackData, index = null) {
                        if (index !== null) currentIndex = index;
                        audioPlayer.src = trackData.audio;
                        audioPlayer.play();
                        currentTrackTitle.innerText = trackData.title;
                        currentTrackArtist.innerText = trackData.artist;
                        currentAlbumArt.src = trackData.image;
                        currentArtist = trackData.artist;
                        updateRecommendationsLink(trackData.artist);
                        updateNavButtons();
                    }

                    document.addEventListener('click', (e) => {
                        if (e.target.closest('.like-btn') || e.target.closest('.add-playlist-btn')) return;
                        const card = e.target.closest('.song-card');
                        if (card) {
                            const trackData = {
                                id: card.dataset.id,
                                audio: card.dataset.audio,
                                title: card.dataset.title,
                                artist: card.dataset.artist,
                                image: card.dataset.image
                            };
                            const existsIndex = playlist.findIndex(s => s.id == trackData.id);
                            if (existsIndex === -1) {
                                playlist.push(trackData);
                                currentIndex = playlist.length - 1;
                            } else {
                                currentIndex = existsIndex;
                            }
                            document.querySelectorAll('.song-card').forEach(c => c.classList.remove('active'));
                            card.classList.add('active');
                            playTrack(trackData, currentIndex);
                        }
                    });

                    audioPlayer.addEventListener('ended', () => {
                        if (playlist.length > 0 && currentIndex < playlist.length - 1) {
                            currentIndex++;
                            playTrack(playlist[currentIndex]);
                        } else {
                            updateNavButtons();
                        }
                    });

                    prevBtn.addEventListener('click', () => {
                        if (currentIndex > 0) {
                            currentIndex--;
                            playTrack(playlist[currentIndex]);
                        }
                    });

                    nextBtn.addEventListener('click', () => {
                        if (currentIndex < playlist.length - 1) {
                            currentIndex++;
                            playTrack(playlist[currentIndex]);
                        }
                    });

                    document.addEventListener('click', async (e) => {
                        const likeBtn = e.target.closest('.like-btn');
                        if (likeBtn) {
                            const card = likeBtn.closest('.song-card');
                            const songData = {
                                songId: card.dataset.id,
                                title: card.dataset.title,
                                artist: card.dataset.artist,
                                audioUrl: card.dataset.audio,
                                image: card.dataset.image
                            };
                            try {
                                const response = await fetch('/like', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(songData)
                                });
                                if (response.ok) {
                                    likeBtn.classList.toggle('liked');
                                    likeBtn.innerHTML = likeBtn.classList.contains('liked')
                                        ? '<i class="fas fa-heart"></i>'
                                        : '<i class="far fa-heart"></i>';
                                }
                            } catch (err) {
                                console.error(err);
                            }
                        }
                    });

                    document.addEventListener('click', (e) => {
                        const btn = e.target.closest('.add-playlist-btn');
                        if (btn) {
                            const card = btn.closest('.song-card');
                            const trackData = {
                                id: card.dataset.id,
                                audio: card.dataset.audio,
                                title: card.dataset.title,
                                artist: card.dataset.artist,
                                image: card.dataset.image
                            };
                            const exists = playlist.find(s => s.id == trackData.id);
                            if (!exists) {
                                playlist.push(trackData);
                                btn.innerText = '✔ Added';
                            }
                        }
                    });

                    function updateRecommendationsLink(artist) {
                        const viewBtn = document.getElementById('view-all-recommendations');
                        if (viewBtn) viewBtn.href = `/recommendations/${encodeURIComponent(artist)}`;
                        showRecommendationsBtn.classList.add('pulse');
                    }

                    // --- RECOMMENDATIONS: FETCH & QUEUE SIMILAR SONGS ---
                    showRecommendationsBtn.addEventListener('click', async () => {
                        if (!currentArtist) {
                            showRecommendationsBtn.innerText = '⚠ Play a song first!';
                            setTimeout(() => { showRecommendationsBtn.innerText = 'Recommendations'; }, 2000);
                            return;
                        }
                        showRecommendationsBtn.innerText = '⏳ Loading...';
                        showRecommendationsBtn.disabled = true;
                        try {
                            const res = await fetch(`/api/similar?artist=${encodeURIComponent(currentArtist)}`);
                            const data = await res.json();
                            const tracks = data.tracks || [];
                            let added = 0;
                            tracks.forEach(track => {
                                if (!playlist.find(s => s.id == track.id)) {
                                    playlist.push({ id: track.id, audio: track.audio, title: track.name, artist: track.artist_name, image: track.image || 'https://via.placeholder.com/300' });
                                    added++;
                                }
                            });
                            showRecommendationsBtn.innerText = added > 0 ? `✅ ${added} added to queue!` : '😔 No similar found';
                            showRecommendationsBtn.disabled = false;
                            if (audioPlayer.paused && added > 0) {
                                currentIndex = playlist.length - added;
                                playTrack(playlist[currentIndex], currentIndex);
                            }
                        } catch (err) {
                            console.error(err);
                            showRecommendationsBtn.innerText = '❌ Error';
                            showRecommendationsBtn.disabled = false;
                        }
                        setTimeout(() => { showRecommendationsBtn.innerText = 'Recommendations'; }, 3000);
                    });

                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'ArrowRight') {
                            if (currentIndex < playlist.length - 1) {
                                currentIndex++;
                                playTrack(playlist[currentIndex]);
                            }
                        }
                        if (e.key === 'ArrowLeft') {
                            if (currentIndex > 0) {
                                currentIndex--;
                                playTrack(playlist[currentIndex]);
                            }
                        }
                    });
                });